# Kubernetes cluster topology (used in justfiles/machines.just and justfiles/kubernetes.just)
# Allowed values: minimal | non-ha | ha
TOPOLOGY=minimal

# Environment for machines (used in justfiles/machines.just)
CONTROLPLANE_CPU=2
CONTROLPLANE_RAM=2
CONTROLPLANE_DISK=16
WORKERNODE_CPU=2
WORKERNODE_RAM=4
WORKERNODE_DISK=16

# Kubernetes version (currently not implemented)
KUBERNETES_VERSION=1.35.2

#
# Environment for "mandatory" addons (partially used in justfiles/kubernetes.just)
# For postdeployment updates, see
# See infra/cilium/base/ocirepository.yaml
#
GATEWAYAPI_VERSION=1.4.1
CILIUM_VERSION=1.19.1
FLUXOPERATOR_VERSION=0.41.1
